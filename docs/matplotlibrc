# Matplotlib settings for the website build only.
#
# The documentation workflow points MATPLOTLIB via the MATPLOTLIBRC environment
# variable at this file, and installs the fonts in docs/fonts into the runner
# before rendering. The installed package never reads this file, so plots on the
# website use Poppins while `pip install heormodel` changes nothing.
#
# A high figure resolution keeps text and lines crisp on high-density displays.

font.family: Poppins
font.size: 11
axes.titlesize: 12.5
axes.labelsize: 11
legend.fontsize: 10
xtick.labelsize: 10
ytick.labelsize: 10

figure.dpi: 110
savefig.dpi: 200
